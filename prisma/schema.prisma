generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id            String         @id @default(cuid())
  name          String
  email         String?        @unique
  phone         String?
  company       String?
  status        CustomerStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  condition     String?
  address       String?
  district      String?
  position      String?
  docType       String?
  docNumber     String?
  payments      Payment[]
  subscriptions Subscription[]
  deals         Deal[]         // Added: One-time deals
}

model DocumentCache {
  id        String   @id @default(cuid())
  docType   String
  docNumber String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([docType, docNumber])
}

model Service {
  id            String         @id @default(cuid())
  name          String
  description   String?
  basePrice     Float
  billingCycle  BillingCycle   @default(MONTHLY)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id          String             @id @default(cuid())
  customerId  String
  serviceId   String
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime?
  nextRenewal DateTime?
  price       Float
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  productName String?
  payments    Payment[]
  customer    Customer           @relation(fields: [customerId], references: [id])
  service     Service            @relation(fields: [serviceId], references: [id])
}

model Deal {
  id            String   @id @default(cuid())
  customerId    String
  name          String
  description   String?
  totalAmount   Float
  downPayment   Float?    @default(0)
  status        String   @default("OPEN") // OPEN, COMPLETED, CANCELLED
  contactMethod String?  // WhatsApp, Facebook, Instagram, Referal, etc.
  paymentTerms  String?  @default("50-50")
  installments  Int?     @default(1)
  dealDate      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer      Customer  @relation(fields: [customerId], references: [id])
  payments      Payment[]
}

model Payment {
  id             String        @id @default(cuid())
  amount         Float
  paymentDate    DateTime      @default(now())
  status         PaymentStatus @default(COMPLETED)
  method         PaymentMethod @default(TRANSFER)
  subscriptionId String?
  dealId         String?       // Added: Link to a specific deal
  customerId     String
  notes          String?
  operationNumber String?     // Added: Operation number from voucher
  targetAccount  String?      // Added: Bank account or digital wallet
  voucherUrl     String?      // Added: Reference to receipt/voucher
  createdAt      DateTime      @default(now())

  customer       Customer      @relation(fields: [customerId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  deal           Deal?         @relation(fields: [dealId], references: [id])
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  LEAD
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  YAPE      // Added
  PLIN      // Added
  OTHERS
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
